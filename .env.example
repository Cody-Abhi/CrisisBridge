# CrisisSync — Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git — it's already in .gitignore

# ────────────────────────────────────────────────────────────────
# FIREBASE CONFIG
# Found in Firebase Console → Project Settings → Your Apps → Web App
# ────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSy...your_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ────────────────────────────────────────────────────────────────
# GOOGLE GEMINI API KEY
# Get from: https://aistudio.google.com/app/apikey
# Used for: Guest safety chatbot + Admin AI Assistant
# ────────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=AIzaSy...your_gemini_key_here
